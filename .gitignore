# ── Frontend (React + Vite) ──────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/*.local
node_modules/
dist/

# ── Backend (Python / FastAPI) ───────────────────────────
backend/__pycache__/
backend/**/__pycache__/
*.py[cod]
*$py.class
backend/venv/
backend/.venv/
venv/
.venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Databases (do NOT commit local data) ─────────────────
*.sqlite3
*.db
backend/app/database/*.db
backend/app/database/*.sqlite3

# ── ChromaDB (vector store data) ─────────────────────────
chroma/
chromadb/
**/chroma_db/
**/.chroma/

# ── Environment variables & secrets ──────────────────────
.env
.env.local
.env.*.local
frontend/.env
backend/.env
**/secrets.json
**/*api_key*

# ── Uploaded content (user PDFs / cached scrapes) ────────
backend/uploads/
backend/app/uploads/
**/tmp_uploads/

# ── Docker ────────────────────────────────────────────────
*.pid
docker-compose.override.yml

# ── Logs ──────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ── Build artifacts ───────────────────────────────────────
build/
*.tsbuildinfo