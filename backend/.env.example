# ============================================================
# MaskaStorage Backend — Environment Variables (Example)
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ─── Application ─────────────────────────────────────────
APP_NAME=MaskaStorage
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ─── API Server ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── CORS ────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/maskadb
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ─── OpenAI / LLM ────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# ─── Vector Store ────────────────────────────────────────
VECTOR_STORE_TYPE=chromadb
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=maska-index

# ─── Storage ─────────────────────────────────────────────
UPLOAD_DIR=app/data/uploads
PROCESSED_DIR=app/data/processed
CACHE_DIR=app/data/cache
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,txt,md,html

# ─── Security ────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
API_KEY_HEADER=X-API-Key
RATE_LIMIT_PER_MINUTE=60

# ─── AWS (optional) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=maska-storage-bucket
